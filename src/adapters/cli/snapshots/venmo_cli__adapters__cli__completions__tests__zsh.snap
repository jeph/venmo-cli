---
source: src/adapters/cli/completions.rs
expression: output
---
#compdef venmo

autoload -U is-at-least

_venmo() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-v[Write redacted diagnostics to stderr]' \
'--verbose[Write redacted diagnostics to stderr]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_venmo_commands" \
"*::: :->venmo" \
&& ret=0
    case $state in
    (venmo)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:venmo-command-$line[1]:"
        case $line[1] in
            (auth)
_arguments "${_arguments_options[@]}" : \
'-v[Write redacted diagnostics to stderr]' \
'--verbose[Write redacted diagnostics to stderr]' \
'-h[Print help]' \
'--help[Print help]' \
":: :_venmo__subcmd__auth_commands" \
"*::: :->auth" \
&& ret=0

    case $state in
    (auth)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:venmo-auth-command-$line[1]:"
        case $line[1] in
            (login)
_arguments "${_arguments_options[@]}" : \
'--token[Import a bearer token and prompt for its matching device ID when needed]' \
'-v[Write redacted diagnostics to stderr]' \
'--verbose[Write redacted diagnostics to stderr]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(reauthenticate)
_arguments "${_arguments_options[@]}" : \
'-v[Write redacted diagnostics to stderr]' \
'--verbose[Write redacted diagnostics to stderr]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(logout)
_arguments "${_arguments_options[@]}" : \
'--revoke[Attempt to revoke the bearer token before deleting it locally]' \
'-v[Write redacted diagnostics to stderr]' \
'--verbose[Write redacted diagnostics to stderr]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'-v[Write redacted diagnostics to stderr]' \
'--verbose[Write redacted diagnostics to stderr]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_venmo__subcmd__auth__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:venmo-auth-help-command-$line[1]:"
        case $line[1] in
            (login)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(reauthenticate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(logout)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(pay)
_arguments "${_arguments_options[@]}" : \
'--note=[Non-empty payment note]:NOTE:_default' \
'--visibility=[Visibility of the created payment]:VISIBILITY:(private friends public)' \
'--yes[Skip only the final default-No confirmation]' \
'-v[Write redacted diagnostics to stderr]' \
'--verbose[Write redacted diagnostics to stderr]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':recipient -- Exact username with an optional leading @:_default' \
':amount -- Positive USD amount with at most two fractional digits:_default' \
&& ret=0
;;
(request)
_arguments "${_arguments_options[@]}" : \
'--note=[Non-empty request note]:NOTE:_default' \
'--visibility=[Visibility of the created request]:VISIBILITY:(private friends public)' \
'-v[Write redacted diagnostics to stderr]' \
