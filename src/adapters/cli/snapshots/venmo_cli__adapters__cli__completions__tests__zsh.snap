(( $+functions[_venmo_commands] )) ||
_venmo_commands() {
    local commands; commands=(
'auth:Validate and manage the stored Venmo bearer token' \
'pay:Pay one person' \
'request:Create a request immediately' \
'accept:Accept an incoming request after authoritative validation and confirmation' \
'decline:Decline an incoming request without sending money' \
'friends:Inspect friends of the active account' \
'users:Find Venmo users' \
'payment-methods:Inspect available payment methods' \
'balance:Show the Venmo wallet balance' \
'activity:Inspect account activity' \
'requests:Inspect pending requests' \
'doctor:Run read-only diagnostics' \
'completions:Generate shell completion source' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'venmo commands' commands "$@"
}
(( $+functions[_venmo__subcmd__accept_commands] )) ||
_venmo__subcmd__accept_commands() {
    local commands; commands=()
    _describe -t commands 'venmo accept commands' commands "$@"
}
(( $+functions[_venmo__subcmd__activity_commands] )) ||
_venmo__subcmd__activity_commands() {
    local commands; commands=(
'list:List recent activity' \
'info:Show information about one activity record' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'venmo activity commands' commands "$@"
}
(( $+functions[_venmo__subcmd__activity__subcmd__help_commands] )) ||
_venmo__subcmd__activity__subcmd__help_commands() {
    local commands; commands=(
'list:List recent activity' \
'info:Show information about one activity record' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'venmo activity help commands' commands "$@"
}
