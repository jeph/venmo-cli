        'venmo;help;payment-methods' {
            [CompletionResult]::new('list', 'list', [CompletionResultType]::ParameterValue, 'List payment methods and copyable IDs')
            break
        }
        'venmo;help;payment-methods;list' {
            break
        }
        'venmo;help;balance' {
            break
        }
        'venmo;help;activity' {
            [CompletionResult]::new('list', 'list', [CompletionResultType]::ParameterValue, 'List recent activity')
            [CompletionResult]::new('info', 'info', [CompletionResultType]::ParameterValue, 'Show information about one activity record')
            break
        }
        'venmo;help;activity;list' {
            break
        }
        'venmo;help;activity;info' {
            break
        }
        'venmo;help;requests' {
            [CompletionResult]::new('list', 'list', [CompletionResultType]::ParameterValue, 'List pending requests involving the active account')
            [CompletionResult]::new('info', 'info', [CompletionResultType]::ParameterValue, 'Show information about one open request')
            break
        }
        'venmo;help;requests;list' {
            break
        }
        'venmo;help;requests;info' {
            break
        }
        'venmo;help;doctor' {
            break
        }
        'venmo;help;completions' {
            break
        }
        'venmo;help;help' {
            break
        }
    })

    $completions.Where{ $_.CompletionText -like "$wordToComplete*" } |
        Sort-Object -Property ListItemText
}
