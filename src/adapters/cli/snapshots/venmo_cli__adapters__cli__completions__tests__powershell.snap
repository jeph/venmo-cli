---
source: src/adapters/cli/completions.rs
expression: output
---

using namespace System.Management.Automation
using namespace System.Management.Automation.Language

Register-ArgumentCompleter -Native -CommandName 'venmo' -ScriptBlock {
    param($wordToComplete, $commandAst, $cursorPosition)

    $commandElements = $commandAst.CommandElements
    $command = @(
        'venmo'
        for ($i = 1; $i -lt $commandElements.Count; $i++) {
            $element = $commandElements[$i]
            if ($element -isnot [StringConstantExpressionAst] -or
                $element.StringConstantType -ne [StringConstantType]::BareWord -or
                $element.Value.StartsWith('-') -or
                $element.Value -eq $wordToComplete) {
                break
        }
        $element.Value
    }) -join ';'

    $completions = @(switch ($command) {
        'venmo' {
            [CompletionResult]::new('-v', '-v', [CompletionResultType]::ParameterName, 'Write redacted diagnostics to stderr')
            [CompletionResult]::new('--verbose', '--verbose', [CompletionResultType]::ParameterName, 'Write redacted diagnostics to stderr')
            [CompletionResult]::new('-h', '-h', [CompletionResultType]::ParameterName, 'Print help (see more with ''--help'')')
            [CompletionResult]::new('--help', '--help', [CompletionResultType]::ParameterName, 'Print help (see more with ''--help'')')
            [CompletionResult]::new('-V', '-V ', [CompletionResultType]::ParameterName, 'Print version')
            [CompletionResult]::new('--version', '--version', [CompletionResultType]::ParameterName, 'Print version')
            [CompletionResult]::new('auth', 'auth', [CompletionResultType]::ParameterValue, 'Validate and manage the stored Venmo bearer token')
            [CompletionResult]::new('pay', 'pay', [CompletionResultType]::ParameterValue, 'Pay one person')
            [CompletionResult]::new('request', 'request', [CompletionResultType]::ParameterValue, 'Create a request immediately')
            [CompletionResult]::new('accept', 'accept', [CompletionResultType]::ParameterValue, 'Accept an incoming request after authoritative validation and confirmation')
            [CompletionResult]::new('decline', 'decline', [CompletionResultType]::ParameterValue, 'Decline an incoming request without sending money')
            [CompletionResult]::new('friends', 'friends', [CompletionResultType]::ParameterValue, 'Inspect friends of the active account')
            [CompletionResult]::new('users', 'users', [CompletionResultType]::ParameterValue, 'Find Venmo users')
            [CompletionResult]::new('payment-methods', 'payment-methods', [CompletionResultType]::ParameterValue, 'Inspect available payment methods')
            [CompletionResult]::new('balance', 'balance', [CompletionResultType]::ParameterValue, 'Show the Venmo wallet balance')
            [CompletionResult]::new('activity', 'activity', [CompletionResultType]::ParameterValue, 'Inspect account activity')
            [CompletionResult]::new('requests', 'requests', [CompletionResultType]::ParameterValue, 'Inspect pending requests')
            [CompletionResult]::new('doctor', 'doctor', [CompletionResultType]::ParameterValue, 'Run read-only diagnostics')
            [CompletionResult]::new('completions', 'completions', [CompletionResultType]::ParameterValue, 'Generate shell completion source')
            [CompletionResult]::new('help', 'help', [CompletionResultType]::ParameterValue, 'Print this message or the help of the given subcommand(s)')
            break
        }
        'venmo;auth' {
            [CompletionResult]::new('-v', '-v', [CompletionResultType]::ParameterName, 'Write redacted diagnostics to stderr')
            [CompletionResult]::new('--verbose', '--verbose', [CompletionResultType]::ParameterName, 'Write redacted diagnostics to stderr')
            [CompletionResult]::new('-h', '-h', [CompletionResultType]::ParameterName, 'Print help')
            [CompletionResult]::new('--help', '--help', [CompletionResultType]::ParameterName, 'Print help')
            [CompletionResult]::new('login', 'login', [CompletionResultType]::ParameterValue, 'Authenticate with a trusted device and password/SMS OTP, or import a bearer token')
            [CompletionResult]::new('reauthenticate', 'reauthenticate', [CompletionResultType]::ParameterValue, 'Replace an expired token using the stored trusted device and password/SMS OTP')
            [CompletionResult]::new('logout', 'logout', [CompletionResultType]::ParameterValue, 'Remove the locally stored credential')
            [CompletionResult]::new('status', 'status', [CompletionResultType]::ParameterValue, 'Validate the credential and show the active account')
            [CompletionResult]::new('help', 'help', [CompletionResultType]::ParameterValue, 'Print this message or the help of the given subcommand(s)')
